{
  "name": "horde-io",
  "version": "2.0.0",
  "description": "Horde.IO – RTS/Battle-Royale-Hybrid im Mittelalter-Stil. Neuauflage mit TypeScript + Phaser 3 + Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.2",
    "vitest": "^3.2.4"
  }
}
