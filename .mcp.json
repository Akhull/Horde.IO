{
  "mcpServers": {
    "agent-browser": {
      "command": "cmd",
      "args": ["/c", "agent-browser", "mcp", "--tools", "core,debug,network"]
    },
    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT}"
      }
    }
  }
}
